

# CREATE A .env FILE, DO NOT USE THIS.
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
# JawsDB (from Heroku dashboard -> JawsDB MySQL -> Connection Info) ---
# Format: mysql://USER:PASS@HOST:PORT/DATABASE
JAWSDB_URL=mysql://username:password@hostname:3306/database_name
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=soundvault-music
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
